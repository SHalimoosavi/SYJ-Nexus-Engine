{
  "name": "syj-nexus-engine",
  "version": "0.1.0",
  "private": true,
  "description": "SYJ Nexus Engine — a headless, API-first, configuration-driven enterprise operating framework. Bring Your Own Vertical (BYOV).",
  "author": "Syed Ali Hasan Moosavi / SAYANJALI NEXUS PRIVATE LIMITED",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SHalimoosavi/SYJ-Nexus-Engine"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx scripts/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf .next node_modules/.cache data/*.db-journal",
    "health": "tsx scripts/health-check.ts",
    "init": "tsx scripts/init.ts"
  },
  "dependencies": {
    "next": "14.2.15",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "drizzle-orm": "0.33.0",
    "better-sqlite3": "11.3.0",
    "zod": "3.23.8",
    "nanoid": "5.0.7",
    "dotenv": "16.4.5"
  },
  "devDependencies": {
    "typescript": "5.6.3",
    "@types/node": "20.16.11",
    "@types/react": "18.3.11",
    "@types/react-dom": "18.3.1",
    "@types/better-sqlite3": "7.6.11",
    "tailwindcss": "3.4.13",
    "postcss": "8.4.47",
    "autoprefixer": "10.4.20",
    "drizzle-kit": "0.24.2",
    "tsx": "4.19.1",
    "vitest": "2.1.2",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.15"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
