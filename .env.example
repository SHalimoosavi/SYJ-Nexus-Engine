# ---------------------------------------------------------------------------
# SYJ Nexus Engine — Environment Configuration
# Copy this file to .env and fill in real values before running in production.
# Never commit your real .env file.
# ---------------------------------------------------------------------------

# Runtime
NODE_ENV=development
PORT=3000

# Database (SQLite file path, created automatically by init.sh)
DATABASE_PATH=./data/nexus.db

# Session / Auth
# Generate with: openssl rand -hex 32
SESSION_SECRET=replace_this_with_a_64_char_random_hex_string
SESSION_COOKIE_NAME=nexus_session
SESSION_TTL_HOURS=168

# CSRF
CSRF_SECRET=replace_this_with_another_64_char_random_hex_string

# Password hashing (Node built-in scrypt tuning — defaults are safe for most deployments)
SCRYPT_COST=16384
SCRYPT_BLOCK_SIZE=8
SCRYPT_PARALLELIZATION=1

# Rate limiting (requests per window, per IP)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Seed / bootstrap admin account (used only by db:seed, first run)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ORG_NAME=Default Organization

# Logging
LOG_LEVEL=info
